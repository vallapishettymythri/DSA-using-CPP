#include <iostream>
#include <algorithm>
#include <climits>
using namespace std;


int main() {
    /* Enter your code here. Read input from STDIN. Print output to STDOUT */ 
    int n;
    cin>> n;
    int a[n];
    for(int i=0;i<n;i++){
        cin >> a[i];
    }
    int maxsum=INT_MIN;
    for(int st=0;st<n;st++){
        int currsum=0;
        for(int end=st;end<n;end++){
            currsum+=a[end];
            maxsum=max(currsum,maxsum);
        }
    }
    cout << maxsum << endl;
    return 0;
}
