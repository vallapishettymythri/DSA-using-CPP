#include <cmath>
#include <cstdio>
#include <vector>
#include <iostream>
#include <algorithm>
using namespace std;

bool is_perfect(int k) {
        int sum=0;
        for(int i=1;i<k;i++){
            if(k%i==0){
                sum+=i;
            }
        }
            if(sum==k){
                return true;
            }
                else{
                    return false;
                }
            
}
int main(){
    int n;
    cin >>n;
    int found=0;
    for(int i=1;i<=n;i++){
        if(is_perfect(i)){
            cout << i << ' ';
            found=1;
        }
}
    if(found==0){
        cout << "None";
    }
    return 0;
}
