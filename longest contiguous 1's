#include <iostream>
using namespace std;
int main() {
    /* Enter your code here. Read input from STDIN. Print output to STDOUT */   
    int n;
    cin >> n;
    int a[n];
    for(int i=0;i<n;i++){
        cin >> a[i];
    }
    int count=0;
    int max=count;
    for(int i=0;i<n;i++){
        if(a[i]==1){
            count++;
        }else{
            count=0;
        }
        if(count > max){
            max=count;
        }
    }
    cout << max;
    
    return 0;
}
