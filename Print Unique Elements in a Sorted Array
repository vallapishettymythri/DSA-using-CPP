#include <iostream>
using namespace std;


int main() {
    int n;
    cin >> n;
    int temp[n];
    int a[n];
    for(int i=0;i<n;i++){
        cin >> a[i];
    }
    temp[0]=a[0];
    int index=0; #shows the index of last element present in temp array.
    for(int i=1;i<n;i++){
        if(temp[index]!=a[i]){
            index++;
            temp[index]=a[i];
        }
    }
    for(int i=0;i<=index;i++){
        cout << temp[i] << " ";
    }
    return 0;
}
