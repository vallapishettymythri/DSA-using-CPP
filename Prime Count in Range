#include <cmath>
#include <cstdio>
#include <vector>
#include <iostream>
#include <algorithm>
using namespace std;

bool isPrime(int num) {
    if (num <= 1) return false; 
    for (int i = 2; i < num; i++) { 
        if (num % i == 0) return false; 
    }
    return true; 
}

int main() {
    int l, r;
    cin >> l >> r;

    int primeCount = 0;
    
    
    for (int i = l; i <= r; i++) {
        if (isPrime(i)) {
            primeCount++;
        }
    }

    cout << primeCount << endl; 

    return 0;
}
