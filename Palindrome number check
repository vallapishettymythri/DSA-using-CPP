#include <cmath>
#include <cstdio>
#include <vector>
#include <iostream>
#include <algorithm>
using namespace std;


int main() {
    /* Enter your code here. Read input from STDIN. Print output to STDOUT */   
    int n;
    cin >> n;
    int rev=0;
    int temp=n;
    while(n>0){
        rev=rev*10+(n%10);
        n=n/10;
    }
    if(temp==rev){
        cout << "YES";
    }else{
        cout << "NO";
    }
    return 0;
}


